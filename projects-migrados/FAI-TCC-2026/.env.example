# ─────────────────────────────────────────────
# FAI-TCC-2026 (Fashion AI) — Variáveis de ambiente
# NÃO preencher valores reais aqui.
# Copie este arquivo para .env e preencha localmente.
# NUNCA commite o arquivo .env real.
# ─────────────────────────────────────────────

NODE_ENV=development
APP_PORT=3002

# ── Banco de dados MySQL ──────────────────────
DB_HOST=
DB_PORT=3306
DB_NAME=fai_tcc_2026
DB_USER=
DB_PASSWORD=
DB_SSL=false

# ── Sessão / Auth ─────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=12h
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Upload de imagens ─────────────────────────
STORAGE_BUCKET=
STORAGE_BASE_URL=
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ── IA / Integrações externas ─────────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ── Backup ───────────────────────────────────
BACKUP_DIR=./database/backups
BACKUP_RETENTION_DAYS=30

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3002

# ── Firebase (exportação legado) ─────────────
FIREBASE_EXPORT_PROJECT_ID=
