# ─────────────────────────────────────────────
# Scores-p-2026 — Variáveis de ambiente
# NÃO preencher valores reais aqui.
# Copie este arquivo para .env e preencha localmente.
# NUNCA commite o arquivo .env real.
# ─────────────────────────────────────────────

NODE_ENV=development
APP_PORT=3001

# ── Banco de dados MySQL ──────────────────────
DB_HOST=
DB_PORT=3306
DB_NAME=scores_p_2026
DB_USER=
DB_PASSWORD=
DB_SSL=false

# ── Sessão / Auth ─────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Backup ───────────────────────────────────
BACKUP_DIR=./database/backups
BACKUP_RETENTION_DAYS=30

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001
