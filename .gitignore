# This .gitignore is appropriate for repositories deployed to GitHub Pages and using
# a Gemfile as specified at https://github.com/github/pages-gem#conventional

# Basic Jekyll gitignores (synchronize to Jekyll.gitignore)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Additional Ruby/bundler ignore for when you run: bundle install
/vendor

# Specific ignore for GitHub Pages
# GitHub Pages will always use its own deployed version of pages-gem 
# This means GitHub Pages will NOT use your Gemfile.lock and therefore it is
# counterproductive to check this file into the repository.
# Details at https://github.com/github/pages-gem/issues/768
Gemfile.lock
# env
.env
.env.*
.firebase.json
.service.json
.serviceAccountKey.json
# node / next
node_modules/
.next/
out/
dist/
testbcrypt.js
# firebase admin / service account keys
*service*account*.json
*ServiceKey*.json
*firebase-admin*.json
*firebase_admin*.json

# misc
.DS_Store


# [DB-TUNING] Never commit local env files or service account credentials.
.env.local
.env*.local
keys/
*serviceAccount*.json

# projects-migrados — nunca versionar backups ou dumps reais
projects-migrados/**/database/backups/*
!projects-migrados/**/database/backups/.gitkeep
projects-migrados/**/*.sql.gz
projects-migrados/**/*.dump
projects-migrados/**/*.dump.gz
# nunca versionar .env reais dos subprojetos
projects-migrados/**/.env
projects-migrados/**/.env.local
projects-migrados/**/.env.production
# EXCEÇÕES: .env.example e scripts SQL (sem dados reais) devem ser versionados
!projects-migrados/**/.env.example
!projects-migrados/**/database/migrations/*.sql
!projects-migrados/**/database/scripts/*.sql
!projects-migrados/**/database/scripts/*.sh
