# ─────────────────────────────────────────────
# DineExplorer-p-2026 — Variáveis de ambiente
# NÃO preencher valores reais aqui.
# Copie este arquivo para .env e preencha localmente.
# NUNCA commite o arquivo .env real.
# ─────────────────────────────────────────────

NODE_ENV=development
APP_PORT=3000

# ── Banco de dados MySQL ──────────────────────
DB_HOST=
DB_PORT=3306
DB_NAME=dine_explorer_2026
DB_USER=
DB_PASSWORD=
DB_SSL=false

# ── Firebase Admin SDK (server-side) ─────────
NEXT_FIREBASE_ADMIN_PROJECT_ID=
NEXT_FIREBASE_ADMIN_CLIENT_EMAIL=
NEXT_FIREBASE_ADMIN_PRIVATE_KEY=
NEXT_FIREBASE_DATABASE_ID=

# ── Firebase Client SDK (browser) ────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_ID=

# ── Sessão / Auth ─────────────────────────────
PIN_COOKIE_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=12h

# ── IA / Integrações externas ─────────────────
ANTHROPIC_API_KEY=

# ── Backup ───────────────────────────────────
BACKUP_DIR=./database/backups
BACKUP_RETENTION_DAYS=30

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
