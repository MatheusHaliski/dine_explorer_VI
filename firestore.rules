rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // [DB-TUNING] Regras expandidas para raiz restaurants, subcoleção reviews e legado review.
    function signedIn() { return request.auth != null; }
    function isManager(rId) { return signedIn() && request.auth.token.restaurantId == rId && request.auth.token.restaurantRole == "manager"; }
    function isStaff(rId) { return signedIn() && request.auth.token.restaurantId == rId && request.auth.token.restaurantRole in ["manager", "attendant"]; }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isManager(restaurantId);
      match /reviews/{reviewId} { allow read: if true; allow create: if signedIn(); allow update, delete: if isManager(restaurantId); }
      match /members/{uid} { allow read: if isStaff(restaurantId); allow write: if isManager(restaurantId); }
      match /customers/{uid} { allow read, write: if isStaff(restaurantId); }
      match /conversations/{conversationId} { allow read: if isStaff(restaurantId); allow create: if signedIn(); allow update: if isStaff(restaurantId); }
      match /posts/{postId} { allow read: if true; allow write: if isStaff(restaurantId); }
      match /catalog/{itemId} { allow read: if true; allow write: if isManager(restaurantId); }
      match /orders/{orderId} { allow read: if isStaff(restaurantId); allow create: if signedIn(); allow update: if isManager(restaurantId); }
      match /idempotency/{key} { allow read: if false; allow write: if signedIn(); }
    }

    match /review/{reviewId} { allow read: if true; allow create: if signedIn(); allow update, delete: if false; }
  }
}
