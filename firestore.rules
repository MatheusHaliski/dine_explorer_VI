rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roleFor(restaurantId) {
      return signedIn() && request.auth.token.restaurantId == restaurantId
        ? request.auth.token.restaurantRole
        : null;
    }

    function isManager(restaurantId) { return roleFor(restaurantId) == "manager"; }
    function isAttendant(restaurantId) { return roleFor(restaurantId) == "attendant"; }
    function isWorker(restaurantId) { return roleFor(restaurantId) == "worker"; }
    function isStaff(restaurantId) { return isManager(restaurantId) || isAttendant(restaurantId) || isWorker(restaurantId); }

    match /restaurants/{restaurantId}/members/{uid} {
      allow read: if isStaff(restaurantId);
      allow write: if isManager(restaurantId);
    }

    match /restaurants/{restaurantId}/customers/{uid} {
      allow read, write: if isManager(restaurantId) || isAttendant(restaurantId);
    }

    match /restaurants/{restaurantId}/conversations/{conversationId} {
      allow read: if isManager(restaurantId)
        || (isAttendant(restaurantId) && resource.data.assignedToUid == request.auth.uid)
        || (signedIn() && resource.data.clientUid == request.auth.uid);
      allow create: if signedIn();
      allow update: if isManager(restaurantId)
        || isAttendant(restaurantId)
        || (signedIn() && resource.data.clientUid == request.auth.uid);
    }

    match /restaurants/{restaurantId}/posts/{postId} {
      allow read: if true;
      allow write: if isManager(restaurantId) || isAttendant(restaurantId);
    }

    match /restaurants/{restaurantId}/{collectionName}/{docId} {
      allow read: if collectionName in ["stories", "events"];
      allow write: if collectionName in ["stories", "events"] && (isManager(restaurantId) || isAttendant(restaurantId));
      allow read: if collectionName == "ugc" && isStaff(restaurantId);
      allow create: if collectionName == "ugc" && signedIn();
      allow update: if collectionName == "ugc" && (isManager(restaurantId) || isAttendant(restaurantId));
      allow read, write: if collectionName == "issues" && (isManager(restaurantId) || isAttendant(restaurantId));
    }

    match /restaurants/{restaurantId}/operationsChannels/{channelId}/messages/{messageId} {
      allow read, create: if isStaff(restaurantId);
      allow update: if isManager(restaurantId) || isAttendant(restaurantId);
    }

    match /restaurants/{restaurantId}/catalog/{itemId} {
      allow read: if true;
      allow write: if isManager(restaurantId);
      match /reviews/{reviewId} { allow read: if true; allow create: if signedIn(); allow update, delete: if isManager(restaurantId); }
      match /members/{uid} { allow read: if isStaff(restaurantId); allow write: if isManager(restaurantId); }
      match /customers/{uid} { allow read, write: if isStaff(restaurantId); }
      match /conversations/{conversationId} { allow read: if isStaff(restaurantId); allow create: if signedIn(); allow update: if isStaff(restaurantId); }
      match /posts/{postId} { allow read: if true; allow write: if isStaff(restaurantId); }
      match /catalog/{itemId} { allow read: if true; allow write: if isManager(restaurantId); }
      match /orders/{orderId} { allow read: if isStaff(restaurantId); allow create: if signedIn(); allow update: if isManager(restaurantId); }
      match /idempotency/{key} { allow read: if false; allow write: if signedIn(); }
    }

    match /review/{reviewId} { allow read: if true; allow create: if signedIn(); allow update, delete: if false; }
  }
}
